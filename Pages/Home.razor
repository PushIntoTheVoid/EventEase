@page "/"

<PageTitle>Home</PageTitle>

<section class="glass-panel p-4 p-md-5 fade-in-up">
    <p class="text-uppercase mb-2" style="letter-spacing:0.14em;color:#8fa3c8;font-size:.75rem;">Smart Event Platform</p>
    <h1 class="page-title">Plan. Launch. Fill Every Seat.</h1>
    <p class="page-subtitle">Coordinate events with real-time visibility, sleek workflows, and a control room built for high-energy experiences.</p>
    <div class="d-flex flex-wrap gap-2">
        <a href="Events" class="btn btn-primary">Browse Events</a>
        <a href="Register" class="btn btn-outline-light">Quick Register</a>
    </div>
</section>

<section class="event-grid mt-4">
    <article class="glass-card p-4 fade-in-up">
        <h3 class="h5 mb-2">Live Agenda</h3>
        <p class="mb-0" style="color:#c5d0e6;">Monitor schedules, speakers, and venue flow from one dashboard.</p>
    </article>
    <article class="glass-card p-4 fade-in-up">
        <h3 class="h5 mb-2">Attendee Pulse</h3>
        <p class="mb-0" style="color:#c5d0e6;">Track registrations and attendance momentum as events approach.</p>
    </article>
    <article class="glass-card p-4 fade-in-up">
        <h3 class="h5 mb-2">Post-Event Insights</h3>
        <p class="mb-0" style="color:#c5d0e6;">Convert feedback and turnout data into sharper future experiences.</p>
    </article>
</section>
