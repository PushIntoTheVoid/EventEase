@using EventEase.Models

<article class="glass-card p-3 p-md-4 h-100 fade-in-up">
    <h5 class="mb-2">@Event.Name</h5>
    <p style="color:#c5d0e6;">@Event.Description</p>
    <div class="small" style="color:#8fa3c8;">Date: @Event.Date.ToShortDateString()</div>
    <div class="small" style="color:#8fa3c8;">Location: @Event.Location</div>
</article>

@code {
    [Parameter]
    public Event Event { get; set; } = default!;
}
